# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in Vite web/mobile builds.
# In local/dev and Capacitor builds, use this VITE_ prefixed variable.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_API_KEY: Optional compatibility fallback for server/runtime usage.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_FIREBASE_VAPID_KEY: Required for Firebase Cloud Messaging (FCM).
# Get this from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# Use the PUBLIC KEY (key pair starting with "BC..."), NOT the private key
# Example: "BCkHsQlO4xxxxxxxxxx..."
VITE_FIREBASE_VAPID_KEY="YOUR_VAPID_PUBLIC_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Native mobile setup note:
# Google Sign-In for Android/iOS also requires Firebase native config files
# (google-services.json / GoogleService-Info.plist) and SHA fingerprints in Firebase.
#
# FCM Setup:
# 1. Enable Cloud Messaging API in Google Cloud Console
# 2. Generate Web Push certificates in Firebase Console
# 3. Add VITE_FIREBASE_VAPID_KEY to your .env file
# 4. Deploy the functions/ folder to Firebase Functions
